{
  "name": "bonuz-chess",
  "version": "2.0.0",
  "private": true,
  "description": "Bonuz Web3 Chess Platform - Stake, Play, Win",
  "workspaces": [
    "contracts",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:worker": "cd backend && npm run worker",
    "dev:contracts": "cd contracts && npx hardhat node",
    "build": "npm run build:contracts && npm run build:backend && npm run build:frontend",
    "build:contracts": "cd contracts && npx hardhat compile",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "test": "npm run test:contracts && npm run test:backend",
    "test:contracts": "cd contracts && npx hardhat test",
    "test:backend": "cd backend && npm test",
    "deploy:local": "cd contracts && npx hardhat run scripts/deploy.ts --network localhost",
    "deploy:testnet": "cd contracts && npx hardhat run scripts/deploy.ts --network baseSepolia",
    "db:migrate": "cd backend && npx prisma migrate dev",
    "db:generate": "cd backend && npx prisma generate",
    "db:studio": "cd backend && npx prisma studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "clean": "rm -rf node_modules contracts/node_modules backend/node_modules frontend/node_modules"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
