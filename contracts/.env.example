# Deployer wallet private key
DEPLOYER_PRIVATE_KEY=

# Treasury wallet address (receives fees)
TREASURY_ADDRESS=

# Treasury fee in basis points (1000 = 10%)
TREASURY_FEE_BPS=1000

# Stake limits in ETH
MIN_STAKE=0.001
MAX_STAKE=10

# Backend signer address (authorized to finalize games)
BACKEND_SIGNER_ADDRESS=

# RPC URLs
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org

# Block explorer API key
BASESCAN_API_KEY=

# Gas reporter
REPORT_GAS=false
